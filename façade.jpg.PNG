<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Vaïana's Garden">
<link rel="apple-touch-icon" href="apple-touch-icon.png">
<title>Vaïana's Garden – Nouvel Espoir Afro™</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root{--gold:#C9A96E;--gold-light:#E8D5A3;--deep-green:#1A3028;--dark-green:#122219;--sage:#3D5C47;--cream:#FAF6EE;--warm-white:#FDFAF4}
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:'DM Sans','Segoe UI',sans-serif;background:var(--warm-white);color:var(--deep-green);overflow-x:hidden}
  nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:16px 48px;display:flex;justify-content:space-between;align-items:center;background:rgba(26,48,40,0.95);backdrop-filter:blur(10px);border-bottom:1px solid rgba(201,169,110,0.15)}
  .nav-brand{font-family:'Playfair Display',Georgia,serif;font-size:19px;color:var(--cream);font-weight:700}
  .nav-brand span{color:var(--gold);font-style:italic}
  .nav-links{display:flex;gap:24px}
  .nav-links a{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:rgba(250,246,238,0.7);text-decoration:none;transition:color 0.3s}
  .nav-links a:hover{color:var(--gold)}
  .nav-book{background:var(--gold);color:var(--deep-green);font-size:10px;letter-spacing:2px;text-transform:uppercase;padding:10px 20px;border:none;cursor:pointer;font-weight:600;font-family:'DM Sans',sans-serif}
  .hero{min-height:100vh;background:url("data:image/jpeg;base64,") center/cover no-repeat;display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;padding:100px 20px 60px;position:relative}
  .hero::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,25,18,0.72) 0%,rgba(10,25,18,0.82) 100%),radial-gradient(ellipse 60% 60% at 10% 85%,rgba(201,169,110,0.15) 0%,transparent 60%),radial-gradient(ellipse 50% 50% at 90% 15%,rgba(61,92,71,0.4) 0%,transparent 60%)}
  .leaf-svg{position:absolute;pointer-events:none}
  .leaf-tl{top:-50px;left:-50px;width:340px;opacity:0.13;animation:leafSway 8s ease-in-out infinite}
  .leaf-br{bottom:-70px;right:-50px;width:380px;opacity:0.1;animation:leafSway 10s ease-in-out infinite reverse}
  @keyframes leafSway{0%,100%{transform:rotate(-15deg) scale(1)}50%{transform:rotate(-12deg) scale(1.03)}}
  .hero-badge{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);border:1px solid rgba(201,169,110,0.6);padding:7px 24px;border-radius:20px;margin-bottom:36px;position:relative;z-index:2;animation:fadeDown 1s ease both}
  .hero-logo{text-align:center;position:relative;z-index:2;animation:fadeUp 1.2s ease both 0.2s}
  .brand-line1{font-family:'Playfair Display',Georgia,serif;font-size:clamp(58px,12vw,108px);font-weight:700;color:var(--cream);line-height:0.9;letter-spacing:-2px}
  .brand-line2{font-family:'Playfair Display',Georgia,serif;font-size:clamp(58px,12vw,108px);font-weight:700;color:var(--gold);font-style:italic;line-height:1.05}
  .ornament-row{display:flex;align-items:center;gap:16px;justify-content:center;margin:26px 0 22px}
  .orn-line{flex:1;max-width:90px;height:1px;background:linear-gradient(90deg,transparent,var(--gold))}
  .orn-line.r{background:linear-gradient(270deg,transparent,var(--gold))}
  .orn-dots{color:var(--gold);font-size:14px;letter-spacing:10px}
  .brand-sub{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(13px,2.5vw,18px);font-weight:300;letter-spacing:7px;text-transform:uppercase;color:var(--gold-light)}
  .hero-tagline{margin-top:32px;font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(16px,2.5vw,20px);font-style:italic;color:rgba(250,246,238,0.6);text-align:center;max-width:500px;line-height:1.8;position:relative;z-index:2;animation:fadeUp 1.2s ease both 0.5s}
  .hero-ctas{margin-top:48px;display:flex;gap:16px;flex-wrap:wrap;justify-content:center;position:relative;z-index:2;animation:fadeUp 1.2s ease both 0.7s}
  .btn-primary{background:var(--gold);color:var(--deep-green);font-weight:500;font-size:12px;letter-spacing:2px;text-transform:uppercase;padding:16px 38px;border:none;cursor:pointer;transition:all 0.3s;font-family:'DM Sans',sans-serif}
  .btn-primary:hover{background:var(--gold-light);transform:translateY(-2px)}
  .btn-outline{background:transparent;color:var(--cream);font-size:12px;letter-spacing:2px;text-transform:uppercase;padding:16px 38px;border:1px solid rgba(250,246,238,0.3);cursor:pointer;transition:all 0.3s;font-family:'DM Sans',sans-serif}
  .btn-outline:hover{border-color:var(--gold);color:var(--gold)}
  .scroll-hint{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);color:rgba(250,246,238,0.35);font-size:10px;letter-spacing:3px;text-transform:uppercase;display:flex;flex-direction:column;align-items:center;gap:10px}
  .scroll-bar{width:1px;height:40px;background:linear-gradient(180deg,rgba(201,169,110,0.8),transparent);animation:scrollPulse 2s ease-in-out infinite}
  .stats-strip{background:var(--dark-green);padding:70px 40px;display:flex;justify-content:center;gap:80px;flex-wrap:wrap;border-top:1px solid rgba(201,169,110,0.2)}
  .stat{text-align:center}
  .stat-num{font-family:'Playfair Display',Georgia,serif;font-size:52px;font-weight:700;color:var(--gold);line-height:1}
  .stat-label{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(250,246,238,0.55);margin-top:10px}
  .sec-label{font-size:10px;letter-spacing:5px;text-transform:uppercase;color:var(--gold);margin-bottom:14px;display:block}
  .sec-title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(32px,5vw,54px);font-weight:400;line-height:1.1;margin-bottom:24px}
  .sec-title em{font-style:italic;color:var(--sage)}
  .sec-title.light{color:var(--cream)}
  .sec-title.light em{color:var(--gold)}
  /* VISION */
  .vision-sec{padding:100px 40px}
  .vision-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
  .vision-text p{font-size:15px;line-height:1.95;color:#4A5C50;margin-bottom:18px}
  .pillars{display:flex;flex-direction:column;gap:16px;margin-top:32px}
  .pillar{display:flex;align-items:flex-start;gap:16px;padding:20px;background:var(--cream);border-left:3px solid var(--gold)}
  .pillar-icon{font-size:26px;flex-shrink:0}
  .pillar-title{font-family:'Playfair Display',Georgia,serif;font-size:16px;font-weight:700;color:var(--deep-green);margin-bottom:4px}
  .pillar-desc{font-size:13px;line-height:1.7;color:var(--sage)}
  .vision-img{aspect-ratio:4/5;position:relative;overflow:hidden;background:linear-gradient(145deg,#2E5040,#1A3028)}
  .vision-img img{width:100%;height:100%;object-fit:cover;display:block}
  .vision-cap{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(26,48,40,0.92));padding:32px 24px 24px}
  .vision-cap span{font-family:'Playfair Display',Georgia,serif;font-size:18px;font-style:italic;color:var(--cream)}
  /* GALERIE */
  .galerie-sec{background:var(--deep-green);padding:100px 40px}
  .galerie-inner{max-width:1200px;margin:0 auto}
  .galerie-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:48px}
  .g-card{position:relative;overflow:hidden;aspect-ratio:4/3;background:linear-gradient(145deg,#2E5040,#1A3028)}
  .g-card img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.6s}
  .g-card:hover img{transform:scale(1.05)}
  .g-overlay{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(26,48,40,0.92));padding:28px 20px 20px}
  .g-tag{color:var(--gold);font-size:10px;letter-spacing:3px;text-transform:uppercase;display:block;margin-bottom:4px}
  .g-name{font-family:'Playfair Display',Georgia,serif;font-size:20px;color:var(--cream)}
  /* SERVICES */
  .services-sec{padding:100px 40px}
  .services-inner{max-width:1200px;margin:0 auto}
  .svc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:2px;background:var(--gold-light);margin-top:48px}
  .svc-card{background:var(--warm-white);padding:44px 30px;transition:all 0.4s;position:relative;overflow:hidden}
  .svc-card::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:3px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform 0.4s}
  .svc-card:hover::after{transform:scaleX(1)}
  .svc-card:hover{background:var(--cream)}
  .svc-icon{font-size:38px;margin-bottom:20px;display:block}
  .svc-name{font-family:'Playfair Display',Georgia,serif;font-size:21px;font-weight:700;color:var(--deep-green);margin-bottom:12px}
  .svc-desc{font-size:14px;line-height:1.85;color:var(--sage);margin-bottom:20px}
  .svc-price{font-family:'Cormorant Garamond',Georgia,serif;font-size:17px;color:var(--gold);font-weight:600}
  /* OUVERTURE */
  .ouv-sec{background:var(--deep-green);padding:100px 40px;text-align:center;position:relative;overflow:hidden}
  .ouv-inner{max-width:680px;margin:0 auto;position:relative;z-index:2}
  .ouv-inner>p{font-size:14px;color:rgba(250,246,238,0.55);line-height:1.8;margin-bottom:0}
  .countdown{display:flex;justify-content:center;gap:40px;flex-wrap:wrap;margin:48px 0}
  .cd-item{text-align:center}
  .cd-num{font-family:'Playfair Display',Georgia,serif;font-size:64px;font-weight:700;color:var(--gold);line-height:1;display:block}
  .cd-lbl{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(250,246,238,0.5);margin-top:8px;display:block}
  .cd-sep{font-size:48px;color:rgba(201,169,110,0.3);align-self:center;padding-bottom:20px}
  /* COMMUNAUTÉ */
  .comm-sec{background:var(--cream);padding:100px 40px;text-align:center}
  .comm-inner{max-width:560px;margin:0 auto}
  .comm-inner>p{font-size:15px;color:var(--sage);line-height:1.85;margin-bottom:40px}
  .comm-form{display:flex;max-width:480px;margin:0 auto}
  .comm-form input{flex:1;padding:16px 20px;border:1px solid rgba(26,48,40,0.2);border-right:none;background:white;font-size:14px;color:var(--deep-green);outline:none;font-family:'DM Sans',sans-serif}
  .comm-form input:focus{border-color:var(--gold)}
  .comm-form button{background:var(--deep-green);color:var(--gold);font-size:11px;letter-spacing:2px;text-transform:uppercase;padding:16px 22px;border:none;cursor:pointer;font-weight:600;font-family:'DM Sans',sans-serif;white-space:nowrap}
  .avantages{display:flex;justify-content:center;gap:28px;flex-wrap:wrap;margin-top:36px}
  .avantage{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--sage)}
  .avantage::before{content:'✦';color:var(--gold);font-size:8px}
  /* CARTE */
  .carte-sec{padding:100px 40px}
  .carte-inner{max-width:1100px;margin:0 auto}
  .carte-inner>p{font-size:15px;color:var(--sage);line-height:1.85;max-width:600px}
  .carte-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px}
  .carte-card{border:1px solid var(--gold-light);padding:40px 28px;position:relative;transition:all 0.4s;background:white}
  .carte-card:hover{transform:translateY(-6px);box-shadow:0 20px 60px rgba(26,48,40,0.12)}
  .carte-card.featured{background:var(--deep-green);border-color:var(--gold)}
  .carte-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--gold);color:var(--deep-green);font-size:9px;letter-spacing:2px;text-transform:uppercase;padding:5px 16px;font-weight:700;white-space:nowrap}
  .carte-tier{font-family:'Playfair Display',Georgia,serif;font-size:22px;font-weight:700;color:var(--deep-green);margin-bottom:8px}
  .carte-card.featured .carte-tier{color:var(--gold)}
  .carte-price{font-family:'Cormorant Garamond',Georgia,serif;font-size:40px;color:var(--gold);font-weight:600;line-height:1;margin-bottom:24px}
  .carte-feats{list-style:none;margin-bottom:28px}
  .carte-feats li{font-size:13px;line-height:2.2;color:var(--sage);display:flex;align-items:center;gap:10px}
  .carte-card.featured .carte-feats li{color:rgba(250,246,238,0.75)}
  .carte-feats li::before{content:'✦';color:var(--gold);font-size:8px;flex-shrink:0}
  .carte-btn{width:100%;padding:14px;background:var(--deep-green);color:var(--gold);font-size:11px;letter-spacing:2px;text-transform:uppercase;border:none;cursor:pointer;font-weight:600;font-family:'DM Sans',sans-serif}
  .carte-card.featured .carte-btn{background:var(--gold);color:var(--deep-green)}
  .form-light{background:var(--cream);border:1px solid var(--gold-light);padding:40px;margin-top:48px;display:none;max-width:560px;margin-left:auto;margin-right:auto}
  .form-light h3{font-family:'Playfair Display',Georgia,serif;font-size:22px;color:var(--deep-green);margin-bottom:8px}
  .form-light>p{font-size:13px;color:var(--sage);margin-bottom:24px}
  /* PARTENAIRES */
  .part-sec{background:var(--dark-green);padding:100px 40px;text-align:center;position:relative;overflow:hidden}
  .part-inner{max-width:720px;margin:0 auto;position:relative;z-index:2}
  .part-inner>p{font-size:15px;color:rgba(250,246,238,0.6);line-height:1.9;margin-bottom:48px}
  .p-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:rgba(201,169,110,0.2);margin-bottom:48px}
  .p-stat{background:rgba(26,48,40,0.8);padding:28px 16px;text-align:center}
  .p-stat-num{font-family:'Playfair Display',Georgia,serif;font-size:32px;color:var(--gold);font-weight:700}
  .p-stat-lbl{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:rgba(250,246,238,0.5);margin-top:8px}
  /* FORMULAIRES */
  .ff{padding:14px;border:1px solid rgba(201,169,110,0.3);background:rgba(255,255,255,0.05);color:var(--cream);font-size:14px;outline:none;font-family:'DM Sans',sans-serif;width:100%;margin-bottom:12px}
  .ff::placeholder{color:rgba(250,246,238,0.35)}
  .ff:focus{border-color:var(--gold)}
  select.ff{-webkit-appearance:none;background:rgba(26,48,40,0.95);color:rgba(250,246,238,0.7)}
  .fl{padding:14px;border:1px solid rgba(26,48,40,0.2);background:white;color:var(--deep-green);font-size:14px;outline:none;font-family:'DM Sans',sans-serif;width:100%;margin-bottom:12px}
  .fl::placeholder{color:rgba(26,48,40,0.35)}
  .fl:focus{border-color:var(--gold)}
  select.fl{-webkit-appearance:none}
  .fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
  .fs-dark{width:100%;padding:16px;background:var(--gold);color:var(--deep-green);font-weight:600;font-size:12px;letter-spacing:3px;text-transform:uppercase;border:none;cursor:pointer;font-family:'DM Sans',sans-serif}
  .fs-light{width:100%;padding:16px;background:var(--deep-green);color:var(--gold);font-weight:600;font-size:12px;letter-spacing:3px;text-transform:uppercase;border:none;cursor:pointer;font-family:'DM Sans',sans-serif}
  .form-overlay{display:none;margin-top:40px;text-align:left;background:rgba(255,255,255,0.04);border:1px solid rgba(201,169,110,0.2);padding:40px}
  .form-overlay h3{font-family:'Playfair Display',Georgia,serif;font-size:24px;color:var(--cream);margin-bottom:8px}
  .form-overlay>p{font-size:13px;color:rgba(250,246,238,0.5);margin-bottom:28px}
  /* RÉSERVATION */
  .resa-sec{background:var(--cream);padding:100px 40px;text-align:center}
  .resa-inner{max-width:580px;margin:0 auto}
  .resa-inner>p{font-size:15px;color:var(--sage);line-height:1.8;margin-bottom:48px}
  .resa-form{display:grid;grid-template-columns:1fr 1fr;gap:10px;text-align:left;margin-bottom:10px}
  .resa-form input,.resa-form select{padding:15px;border:1px solid rgba(26,48,40,0.2);background:white;font-size:14px;color:var(--deep-green);outline:none;-webkit-appearance:none;font-family:'DM Sans',sans-serif}
  .resa-form input:focus,.resa-form select:focus{border-color:var(--gold)}
  .resa-form .full{grid-column:1/-1}
  .btn-book{width:100%;padding:18px;background:var(--deep-green);color:var(--gold);font-weight:500;font-size:12px;letter-spacing:3px;text-transform:uppercase;border:none;cursor:pointer;font-family:'DM Sans',sans-serif}
  /* FOOTER */
  footer{background:var(--deep-green);padding:64px 48px 32px}
  .foot-top{display:flex;justify-content:space-between;flex-wrap:wrap;gap:48px;padding-bottom:48px;border-bottom:1px solid rgba(201,169,110,0.18);margin-bottom:28px}
  .foot-brand{font-family:'Playfair Display',Georgia,serif;font-size:26px;color:var(--cream);font-weight:700}
  .foot-brand span{color:var(--gold);font-style:italic}
  .foot-sub{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-top:8px}
  .foot-col h4{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:20px}
  .foot-col p,.foot-col a{display:block;font-size:13px;line-height:2.3;color:rgba(250,246,238,0.55);text-decoration:none;transition:color 0.2s}
  .foot-col a:hover{color:var(--gold)}
  .foot-bot{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:11px;color:rgba(250,246,238,0.35)}
  .foot-bot span{color:var(--gold)}
  @keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
  @keyframes fadeDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
  @keyframes scrollPulse{0%,100%{opacity:0.4}50%{opacity:1}}
  .fi{opacity:1;transform:none}
  @media(max-width:768px){
    nav{padding:14px 20px}.nav-links{display:none}
    .vision-inner{grid-template-columns:1fr;gap:40px}
    .galerie-grid{grid-template-columns:1fr}
    .vision-sec,.galerie-sec,.services-sec,.ouv-sec,.comm-sec,.carte-sec,.part-sec,.resa-sec{padding:60px 20px}
    .stats-strip{gap:40px;padding:60px 20px}
    .resa-form,.fg2{grid-template-columns:1fr}
    .comm-form{flex-direction:column}.comm-form input{border-right:1px solid rgba(26,48,40,0.2);border-bottom:none}
    footer{padding:48px 20px 24px}.foot-top{flex-direction:column;gap:32px}.foot-bot{flex-direction:column}
    .countdown{gap:16px}.cd-num{font-size:40px}.cd-sep{display:none}
    .p-stats{grid-template-columns:1fr}
    .form-overlay,.form-light{padding:24px}
    .fg2{grid-template-columns:1fr;margin-bottom:0}
  }
</style>
</head>
<body>

<nav>
  <div class="nav-brand">Vaïana'<span>s</span> Garden</div>
  <div class="nav-links">
    <a href="#vision">Vision</a>
    <a href="#services">Services</a>
    <a href="#communaute">Communauté</a>
    <a href="#carte">Carte Fondatrice</a>
    <a href="#partenaires">Partenaires</a>
  </div>
  <button class="nav-book" onclick="document.getElementById('reservation').scrollIntoView({behavior:'smooth'})">Réserver</button>
</nav>

<section class="hero">
  <svg class="leaf-svg leaf-tl" viewBox="0 0 300 400" fill="none"><path d="M50 380 Q150 200 200 20 Q250 200 100 350 Q80 370 50 380Z" fill="#C9A96E"/><path d="M80 360 Q160 220 180 60" stroke="#C9A96E" stroke-width="2" fill="none"/></svg>
  <svg class="leaf-svg leaf-br" viewBox="0 0 300 400" fill="none"><path d="M50 380 Q150 200 200 20 Q250 200 100 350 Q80 370 50 380Z" fill="#3D5C47"/></svg>
  <div class="hero-badge">✦ &nbsp; Bientôt à Parakou, Bénin &nbsp; ✦</div>
  <div class="hero-logo">
    <div class="brand-line1">Vaïana's</div>
    <div class="brand-line2">Garden</div>
    <div class="ornament-row"><div class="orn-line"></div><span class="orn-dots">✦ &nbsp; ✦ &nbsp; ✦</span><div class="orn-line r"></div></div>
    <div class="brand-sub">Nouvel Espoir Afro™</div>
  </div>
  <p class="hero-tagline">Le premier complexe premium dédié aux cheveux afro naturels des enfants — soin, jeu &amp; art de vivre</p>
  <div class="hero-ctas">
    <button class="btn-primary" onclick="document.getElementById('communaute').scrollIntoView({behavior:'smooth'})">Rejoindre la communauté</button>
    <button class="btn-outline" onclick="document.getElementById('vision').scrollIntoView({behavior:'smooth'})">Découvrir le projet</button>
  </div>
  <div class="scroll-hint"><span>Découvrir</span><div class="scroll-bar"></div></div>
</section>

<div class="stats-strip">
  <div class="stat fi"><div class="stat-num">3</div><div class="stat-label">Pôles de revenus</div></div>
