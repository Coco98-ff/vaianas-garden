<script>
  const els=document.querySelectorAll('.fi');
  const obs=new IntersectionObserver((entries)=>{entries.forEach((e,i)=>{if(e.isIntersecting){setTimeout(()=>e.target.classList.add('visible'),i*100);obs.unobserve(e.target);}});},{threshold:0.1});
  els.forEach(el=>obs.observe(el));
  const ouverture=new Date('2026-06-01T00:00:00');
  function updateCountdown(){
    const diff=ouverture-new Date();
    if(diff<=0){document.querySelector('.countdown').innerHTML='<p style="color:var(--gold);font-family:Playfair Display,serif;font-size:28px;font-style:italic">Nous sommes ouverts ! 🎉</p>';return;}
    document.getElementById('days').textContent=String(Math.floor(diff/86400000)).padStart(2,'0');
    document.getElementById('hours').textContent=String(Math.floor((diff%86400000)/3600000)).padStart(2,'0');
    document.getElementById('minutes').textContent=String(Math.floor((diff%3600000)/60000)).padStart(2,'0');
    document.getElementById('seconds').textContent=String(Math.floor((diff%60000)/1000)).padStart(2,'0');
  }
  updateCountdown();setInterval(updateCountdown,1000);

    const f=document.getElementById('form-carte');
    f.style.display='block';
    document.getElementById('carte-hidden').value=tier;
    document.getElementById('carte-tier-lbl').textContent='Carte choisie : '+tier;
    f.scrollIntoView({behavior:'smooth'});
  }
</script>

</body>
